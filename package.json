{
  "name": "hdl-helper",
  "displayName": "HDL Helper",
  "description": "FPGA/IC 全能助手：双引擎语法检查 (Vivado/Verible)、一键格式化、自动 Testbench、智能例化、LSP 跳转与大纲。",
  "version": "3.2.0",
  "publisher": "Cyrus",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Programming Languages",
    "Linters",
    "Formatters",
    "Snippets"
  ],
  "icon": "images/icon_min.png",
  "main": "./out/main.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/Aligo-BTBKS/hdl-helper"
  },
  "contributes": {
    "commands": [
      {
        "command": "hdl-helper.instantiate",
        "title": "HDL: Instantiate Module",
        "category": "HDL Helper"
      },
      {
        "command": "hdl-helper.createSignals",
        "title": "HDL: Create Signal Declarations",
        "category": "HDL Helper"
      },
      {
        "command": "hdl-helper.generateTB",
        "title": "HDL: Generate Testbench",
        "category": "HDL Helper"
      },
      {
        "command": "hdl-helper.debugProject",
        "title": "HDL: Debug Project",
        "category": "HDL Helper"
      },
      {
        "command": "hdl-helper.quickStart",
        "title": "HDL: Quick Actions",
        "category": "HDL Helper"
      },
      {
        "command": "hdl-helper.setTopModule",
        "title": "HDL: Set as Top Module",
        "category": "HDL Helper"
      },
      {
        "command": "hdl-helper.clearTopModule",
        "title": "HDL: Clear Top Module",
        "category": "HDL Helper",
        "icon": "$(clear-all)"
      },
      {
        "command": "hdl-helper.copyInstantiation",
        "title": "HDL: Copy Instantiation Template",
        "category": "HDL Helper"
      },
      {
        "command": "hdl-helper.generateDoc",
        "title": "HDL: Generate Interface Doc",
        "category": "HDL Helper"
      },
      {
        "command": "hdl-helper.listLintRules",
        "title": "HDL: List All Linter Rules",
        "category": "HDL Helper"
      },
      {
        "command": "hdl-helper.runSimulation",
        "title": "HDL: Run Simulation",
        "category": "HDL Helper"
      },
      {
        "command": "hdl-helper.viewWaveform",
        "title": "HDL: View Waveform",
        "category": "HDL Helper"
      },
      {
        "command": "hdl-helper.runSimulationFromHierarchy",
        "title": "HDL: Run Simulation (Hierarchy)",
        "category": "HDL Helper",
        "icon": "$(run-all)"
      },
      {
        "command": "hdl-helper.viewWaveformFromHierarchy",
        "title": "HDL: View Waveform (Hierarchy)",
        "category": "HDL Helper",
        "icon": "$(graph-line)"
      },
      {
        "command": "hdl-helper.runVivadoSynth",
        "title": "HDL: Run Vivado Synthesis",
        "category": "HDL Helper"
      },
      {
        "command": "hdl-helper.runVivadoImpl",
        "title": "HDL: Run Vivado Implementation",
        "category": "HDL Helper"
      },
      {
        "command": "hdl-helper.refreshIpExplorer",
        "title": "HDL: Refresh IP Explorer",
        "category": "HDL Helper",
        "icon": "$(refresh)"
      },
      {
        "command": "hdl-helper.generateFsm",
        "title": "HDL: Visualize FSM (Mermaid)",
        "category": "HDL Helper"
      },
      {
        "command": "hdl-helper.generateAxi",
        "title": "HDL: Generate AXI Interface",
        "category": "HDL Helper"
      },
      {
        "command": "hdl-helper.generateMemory",
        "title": "HDL: Generate Memory IP (FIFO/RAM)",
        "category": "HDL Helper"
      },
      {
        "command": "hdl-helper.generateRegisters",
        "title": "HDL: Generate Register Map from File",
        "category": "HDL Helper"
      },
      {
        "command": "hdl-helper.openSimulationSettings",
        "title": "HDL: Open Simulation Settings",
        "category": "HDL Helper",
        "icon": "$(gear)"
      }
    ],
    "configuration": {
      "title": "HDL Helper",
      "properties": {
        "hdl-helper.signalType": {
          "type": "string",
          "enum": [
            "wire",
            "logic",
            "reg"
          ],
          "default": "logic",
          "description": "自动声明信号时使用的类型 (Auto-declare signal type)"
        },
        "hdl-helper.project.excludeDirs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "node_modules",
            ".srcs",
            ".sim",
            "ip"
          ],
          "description": "解析工程结构时排除的目录名 (Directories to exclude when scanning the project)"
        },
        "hdl-helper.project.filelistPatterns": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "**/*.f",
            "**/*.flist"
          ],
          "description": "工程扫描时识别 filelist 的 glob 模式。若命中 filelist，将优先按 filelist 解析源文件与 include 路径。"
        },
        "hdl-helper.linter.activeEngines": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "verible",
              "vivado",
              "verilator"
            ]
          },
          "default": [
            "verible"
          ],
          "description": "激活的 Lint 引擎列表（可多选，并发执行）。可选：'verible', 'vivado', 'verilator'"
        },
        "hdl-helper.linter.veriblePath": {
          "type": "string",
          "default": "verible-verilog-lint",
          "description": "Path to verible-verilog-lint executable."
        },
        "hdl-helper.linter.verilatorPath": {
          "type": "string",
          "default": "verilator",
          "description": "Verilator 可执行文件路径 (Path to verilator executable). 如已在 PATH 中，保持默认值即可。"
        },
        "hdl-helper.linter.verilatorFlags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "传递给 Verilator 的额外参数 (Extra flags for Verilator)，例如: [\"-Wno-WIDTH\", \"--bbox-sys\"]。"
        },
        "hdl-helper.linter.executablePath": {
          "type": "string",
          "default": "xvlog",
          "description": "Linter 可执行文件路径 (例如: D:\\Xilinx\\Vivado\\2022.1\\bin\\xvlog.bat)。如果已在 PATH 中，保留默认值 'xvlog' 即可。",
          "scope": "resource"
        },
        "hdl-helper.formatter.executablePath": {
          "type": "string",
          "default": "verible-verilog-format",
          "description": "Verible 格式化工具的路径 (Path to verible-verilog-format executable).",
          "scope": "resource"
        },
        "hdl-helper.formatter.flags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "传递给 Verible Formatter 的额外参数 (Extra flags for verible-verilog-format)，例如: [\"--column_limit=120\", \"--lines=1-200\"]。",
          "scope": "resource"
        },
        "hdl-helper.languageServer.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable Verible Language Server (LSP)."
        },
        "hdl-helper.languageServer.path": {
          "type": "string",
          "default": "verible-verilog-ls",
          "description": "Path to verible-verilog-ls executable."
        },
        "hdl-helper.simulation.tasksFile": {
          "type": "string",
          "default": ".vscode/hdl_tasks.json",
          "description": "仿真任务文件路径 (相对工作区或绝对路径)。"
        },
        "hdl-helper.simulation.iverilogPath": {
          "type": "string",
          "default": "iverilog",
          "description": "Icarus Verilog 编译器路径 (iverilog)。如果未加入 PATH，请配置绝对路径。"
        },
        "hdl-helper.simulation.vvpPath": {
          "type": "string",
          "default": "vvp",
          "description": "Icarus Verilog 运行器路径 (vvp)。如果未加入 PATH，请配置绝对路径。"
        },
        "hdl-helper.simulation.buildDir": {
          "type": "string",
          "default": "build",
          "description": "仿真构建输出目录 (相对工作区或绝对路径)。"
        },
        "hdl-helper.simulation.defaultFlags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "-g2012"
          ],
          "description": "未在任务中显式指定 flags 时使用的默认仿真编译参数。"
        },
        "hdl-helper.simulation.autoOpenWaveform": {
          "type": "boolean",
          "default": true,
          "description": "仿真完成后是否弹出波形打开提示。"
        },
        "hdl-helper.linter.rules": {
          "type": "object",
          "markdownDescription": "Verible Linter 规则配置。\n\n* **Key**: 输入 Verible 规则名称 (例如 `always-comb`, `struct-union-name-style`)\n* **Value**: 输入 `true`(启用), `false`(禁用), 或配置字符串 (例如 `length:120`)\n\n可通过命令 `HDL Helper: List All Linter Rules` 查看所有可用规则。",
          "default": {
            "line-length": "length:150",
            "no-tabs": true,
            "no-trailing-spaces": true
          },
          "additionalProperties": {
            "anyOf": [
              {
                "type": "boolean",
                "description": "设置为 true 启用规则，false 禁用规则"
              },
              {
                "type": "string",
                "description": "传递具体的参数，例如 'length:120'"
              }
            ]
          }
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "hdl-explorer",
          "title": "HDL Explorer",
          "icon": "$(chip)"
        }
      ]
    },
    "views": {
      "hdl-explorer": [
        {
          "id": "hdl-hierarchy-view",
          "name": "Module Hierarchy",
          "icon": "images/icon_min.png"
        },
        {
          "id": "ip-explorer-view",
          "name": "IP Explorer",
          "icon": "$(server)"
        }
      ]
    },
    "keybindings": [
      {
        "command": "hdl-helper.instantiate",
        "key": "ctrl+alt+i",
        "mac": "cmd+alt+i",
        "when": "editorTextFocus && (resourceLangId == verilog || resourceLangId == systemverilog)"
      },
      {
        "command": "hdl-helper.createSignals",
        "key": "ctrl+alt+w",
        "mac": "cmd+alt+w",
        "when": "editorTextFocus && (resourceLangId == verilog || resourceLangId == systemverilog)"
      },
      {
        "command": "hdl-helper.generateTB",
        "key": "ctrl+alt+t",
        "mac": "cmd+alt+t",
        "when": "editorTextFocus && (resourceLangId == verilog || resourceLangId == systemverilog)"
      },
      {
        "command": "hdl-helper.generateFsm",
        "key": "ctrl+alt+f",
        "mac": "cmd+alt+f",
        "when": "editorTextFocus && (resourceLangId == verilog || resourceLangId == systemverilog)"
      },
      {
        "command": "hdl-helper.generateAxi",
        "key": "ctrl+alt+a",
        "mac": "cmd+alt+a",
        "when": "editorTextFocus && (resourceLangId == verilog || resourceLangId == systemverilog)"
      },
      {
        "command": "hdl-helper.generateMemory",
        "key": "ctrl+alt+m",
        "mac": "cmd+alt+m",
        "when": "editorTextFocus && (resourceLangId == verilog || resourceLangId == systemverilog)"
      },
      {
        "command": "hdl-helper.generateRegisters",
        "key": "ctrl+alt+r",
        "mac": "cmd+alt+r",
        "when": "editorTextFocus && (resourceLangId == verilog || resourceLangId == systemverilog)"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "hdl-helper.instantiate",
          "group": "hdl-group@1",
          "when": "editorTextFocus && (resourceLangId == verilog || resourceLangId == systemverilog)"
        },
        {
          "command": "hdl-helper.createSignals",
          "group": "hdl-group@2",
          "when": "editorTextFocus && (resourceLangId == verilog || resourceLangId == systemverilog)"
        },
        {
          "command": "hdl-helper.generateTB",
          "group": "hdl-group@3",
          "when": "editorTextFocus && (resourceLangId == verilog || resourceLangId == systemverilog)"
        },
        {
          "command": "hdl-helper.generateFsm",
          "group": "hdl-group@4",
          "when": "editorTextFocus && (resourceLangId == verilog || resourceLangId == systemverilog)"
        },
        {
          "command": "hdl-helper.generateAxi",
          "group": "hdl-group@5",
          "when": "editorTextFocus && (resourceLangId == verilog || resourceLangId == systemverilog)"
        },
        {
          "command": "hdl-helper.generateMemory",
          "group": "hdl-group@5",
          "when": "editorTextFocus && (resourceLangId == verilog || resourceLangId == systemverilog)"
        },
        {
          "command": "hdl-helper.generateRegisters",
          "group": "hdl-group@5",
          "when": "editorTextFocus && (resourceLangId == verilog || resourceLangId == systemverilog)"
        }
      ],
      "view/title": [
        {
          "command": "hdl-helper.quickStart",
          "when": "view == hdl-hierarchy-view",
          "group": "navigation"
        },
        {
          "command": "hdl-helper.clearTopModule",
          "when": "view == hdl-hierarchy-view",
          "group": "navigation"
        },
        {
          "command": "hdl-helper.runSimulationFromHierarchy",
          "when": "view == hdl-hierarchy-view",
          "group": "navigation@1"
        },
        {
          "command": "hdl-helper.viewWaveformFromHierarchy",
          "when": "view == hdl-hierarchy-view",
          "group": "navigation@2"
        },
        {
          "command": "hdl-helper.openSimulationSettings",
          "when": "view == hdl-hierarchy-view",
          "group": "navigation@3"
        },
        {
          "command": "hdl-helper.refreshIpExplorer",
          "when": "view == ip-explorer-view",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "hdl-helper.setTopModule",
          "when": "view == hdl-hierarchy-view && viewItem == module",
          "group": "1_modification"
        },
        {
          "command": "hdl-helper.clearTopModule",
          "when": "view == hdl-hierarchy-view",
          "group": "1_modification"
        },
        {
          "command": "hdl-helper.copyInstantiation",
          "when": "view == hdl-hierarchy-view && viewItem == module",
          "group": "2_codegen"
        },
        {
          "command": "hdl-helper.generateTB",
          "when": "view == hdl-hierarchy-view && viewItem == module",
          "group": "2_codegen"
        },
        {
          "command": "hdl-helper.generateDoc",
          "when": "view == hdl-hierarchy-view && viewItem == module",
          "group": "3_documentation"
        },
        {
          "command": "hdl-helper.runSimulationFromHierarchy",
          "when": "view == hdl-hierarchy-view && viewItem == module",
          "group": "inline@1"
        },
        {
          "command": "hdl-helper.viewWaveformFromHierarchy",
          "when": "view == hdl-hierarchy-view && viewItem == module",
          "group": "inline@2"
        }
      ]
    },
