    "languages": [
      {
        "id": "verilog",
        "aliases": [
          "Verilog",
          "v"
        ],
        "extensions": [
          ".v",
          ".vh",
          ".vl"
        ],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "systemverilog",
        "aliases": [
          "SystemVerilog",
          "sv"
        ],
        "extensions": [
          ".sv",
          ".svh",
          ".sva"
        ],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "sdc",
        "aliases": [
          "SDC",
          "sdc"
