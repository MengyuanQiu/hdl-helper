{
    "Mealy Three-Segment FSM": {
        "prefix": "fsm (mealy)",
        "body": [
            "// Module: ${1:module_name}",
            "// Style:  3-Segment Mealy FSM (Registered Outputs)",
            "",
            "// --- 1. State Definitions ---",
            "typedef enum logic [${2:1}:0] {",
            "    ${3:IDLE}   = ${2:1}'d0,",
            "    ${4:BUSY}   = ${2:1}'d1${5:,}",
            "    ${6:DONE}   = ${2:1}'d2",
            "} ${7:state}_t;",
            "",
            "${7:state}_t curr_state, next_state;",
            "",
            "// --- 2. State Register (Sequential) ---",
            "always_ff @(posedge clk or negedge rst_n) begin",
            "    if (!rst_n) curr_state <= ${3:IDLE};",
            "    else        curr_state <= next_state;",
            "end",
            "",
            "// --- 3. Next State Logic (Combinational) ---",
            "always_comb begin",
            "    next_state = curr_state; // Default: hold state",
            "    case (curr_state)",
            "        ${3:IDLE}: begin",
            "            if (${8:start_in}) next_state = ${4:BUSY};",
            "        end",
            "        ${4:BUSY}: begin",
            "            if (${9:done_in})  next_state = ${6:DONE};",
            "        end",
            "        ${6:DONE}: begin",
            "            next_state = ${3:IDLE};",
            "        end",
            "        default: next_state = ${3:IDLE};",
            "endcase",
            "end",
            "",
            "// --- 4. Mealy Output Logic (Registered to avoid glitches) ---",
            "// Note: Output depends on BOTH curr_state and inputs (via next_state logic)",
            "always_ff @(posedge clk or negedge rst_n) begin",
            "    if (!rst_n) begin",
            "        ${10:out_signal} <= 1'b0;",
            "    end else begin",
            "        case (curr_state)",
            "            ${3:IDLE}: begin",
            "                // Mealy Effect: Output transitions immediately when input arrives",
            "                if (${8:start_in}) ${10:out_signal} <= 1'b1;",
            "                else               ${10:out_signal} <= 1'b0;",
            "            end",
            "            ${4:BUSY}: begin",
            "                if (${9:done_in})  ${10:out_signal} <= 1'b0;",
            "            end",
            "            default: ${10:out_signal} <= 1'b0;",
            "        endcase",
            "    end",
            "end$0"
        ],
        "description": "Optimized 3-segment Mealy FSM with explicit input-dependency in outputs"
    }
}