{
    "Optimized One-Hot Moore FSM": {
        "prefix": "fsm (moore onehot)",
        "body": [
            "// Module: ${1:module_name}",
            "// Style:  One-Hot Encoded Moore FSM (High Performance)",
            "",
            "// --- 1. State Definition (One-Hot) ---",
            "localparam int STATE_W = ${2:3};",
            "typedef enum logic [STATE_W-1:0] {",
            "    ${3:ST_IDLE}   = ${2:3}'b001,",
            "    ${4:ST_ACTIVE} = ${2:3}'b010,",
            "    ${5:ST_DONE}   = ${2:3}'b100",
            "} ${6:state}_t;",
            "",
            "// Synthesis hint for tools like Vivado/Quartus",
            "(* fsm_encoding = \"one_hot\" *) ${6:state}_t curr_state, next_state;",
            "",
            "// --- 2. State Register ---",
            "always_ff @(posedge clk or negedge rst_n) begin",
            "    if (!rst_n) curr_state <= ${3:ST_IDLE};",
            "    else        curr_state <= next_state;",
            "end",
            "",
            "// --- 3. Next State Logic (Optimized for One-Hot) ---",
            "always_comb begin",
            "    next_state = '0; // Default to all zeros, case handles transitions",
            "    unique case (1'b1)",
            "        curr_state[0]: begin // ${3:ST_IDLE}",
            "            if (${7:start_condition}) next_state = ${4:ST_ACTIVE};",
            "            else                      next_state = ${3:ST_IDLE};",
            "        end",
            "        curr_state[1]: begin // ${4:ST_ACTIVE}",
            "            if (${8:done_condition})  next_state = ${5:ST_DONE};",
            "            else                      next_state = ${4:ST_ACTIVE};",
            "        end",
            "        curr_state[2]: begin // ${5:ST_DONE}",
            "            next_state = ${3:ST_IDLE};",
            "        end",
            "        default: next_state = ${3:ST_IDLE};",
            "    endcase",
            "end",
            "",
            "// --- 4. Registered Output Logic (Moore: depends only on state) ---",
            "// Optimization: Using next_state logic to reduce output latency to 0 cycles",
            "// while maintaining a clean registered path.",
            "always_ff @(posedge clk or negedge rst_n) begin",
            "    if (!rst_n) begin",
            "        ${9:out_signal} <= 1'b0;",
            "    end else begin",
            "        // Using bit index instead of full enum comparison for speed",
            "        ${9:out_signal} <= next_state[1]; // High when next state is ACTIVE",
            "    end",
            "end$0"
        ],
        "description": "High Performance Moore FSM with One-Hot encoding optimizations"
    }
}