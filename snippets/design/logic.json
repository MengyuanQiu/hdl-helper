{
    "Synchronous FIFO with FWFT/STD Support": {
        "prefix": "fifo (sync)",
        "body": [
            "`resetall",
            "`timescale 1ns / 1ns",
            "",
            "module ${1:sync_fifo_gen}",
            "import rtl_pkg::*;",
            "#(",
            "    parameter  int FIFO_DEPTH = ${2:16},",
            "    parameter  int FIFO_WIDTH = ${3:32},",
            "    parameter  rtl_mode_e FWFT_MODE = ${4:RTL_MODE_PASSIVE},",
            "    localparam int ADDR_WIDTH = \\$clog2(FIFO_DEPTH),",
            "    localparam int CNT_WIDTH  = \\$clog2(FIFO_DEPTH + 1)",
            ") (",
            "    input  logic                  clk_i,",
            "    input  logic                  rst_ni,",
            "",
            "    // Write Interface",
            "    input  logic                  wr_en_i,",
            "    input  logic [FIFO_WIDTH-1:0] din_i,",
            "    output logic                  full_o,",
            "",
            "    // Read Interface",
            "    input  logic                  rd_en_i,",
            "    output logic [FIFO_WIDTH-1:0] dout_o,",
            "    output logic                  empty_o,",
            "",
            "    // Status",
            "    output logic [CNT_WIDTH-1:0]  wat_level_o",
            ");",
            "",
            "    // 1. Memory & Pointers",
            "    logic [FIFO_WIDTH-1:0] mem [FIFO_DEPTH];",
            "    logic [ADDR_WIDTH:0]   wr_ptr;",
            "    logic [ADDR_WIDTH:0]   rd_ptr;",
            "",
            "    logic                  fifo_wr_en;",
            "    logic                  fifo_rd_en;",
            "    logic                  fifo_full;",
            "    logic                  fifo_empty;",
            "    logic [FIFO_WIDTH-1:0] fifo_dout;",
            "    logic [CNT_WIDTH-1:0]  fifo_cnt;",
            "",
            "    // 2. Status Logic",
            "    assign fifo_full  = (wr_ptr[ADDR_WIDTH] != rd_ptr[ADDR_WIDTH]) && (wr_ptr[ADDR_WIDTH-1:0] == rd_ptr[ADDR_WIDTH-1:0]);",
            "    assign fifo_empty = (wr_ptr == rd_ptr);",
            "    assign fifo_cnt   = wr_ptr - rd_ptr;",
            "    assign fifo_wr_en = wr_en_i && !fifo_full;",
            "",
            "    // 3. Sequential Logic",
            "    always_ff @(posedge clk_i or negedge rst_ni) begin",
            "        if (!rst_ni) wr_ptr <= '0;",
            "        else if (fifo_wr_en) wr_ptr <= wr_ptr + 1'b1;",
            "    end",
            "",
            "    always_ff @(posedge clk_i or negedge rst_ni) begin",
            "        if (!rst_ni) rd_ptr <= '0;",
            "        else if (fifo_rd_en) rd_ptr <= rd_ptr + 1'b1;",
            "    end",
            "",
            "    // Memory Write",
            "    always_ff @(posedge clk_i) begin",
            "        if (fifo_wr_en) mem[wr_ptr[ADDR_WIDTH-1:0]] <= din_i;",
            "    end",
            "",
            "    // Memory Read (Lat=1)",
            "    always_ff @(posedge clk_i) begin",
            "        if (fifo_rd_en) fifo_dout <= mem[rd_ptr[ADDR_WIDTH-1:0]];",
            "    end",
            "",
            "    // 4. Mode Generation",
            "    generate",
            "        if (FWFT_MODE == RTL_MODE_ACTIVE) begin : gen_fwft",
            "            logic skid_valid;",
            "            assign fifo_rd_en = !fifo_empty && (!skid_valid || rd_en_i);",
            "",
            "            always_ff @(posedge clk_i or negedge rst_ni) begin",
            "                if (!rst_ni) skid_valid <= 1'b0;",
            "                else if (fifo_rd_en) skid_valid <= 1'b1;",
            "                else if (rd_en_i)    skid_valid <= 1'b0;",
            "            end",
            "",
            "            assign dout_o      = fifo_dout;",
            "            assign empty_o     = !skid_valid;",
            "            assign full_o      = fifo_full;",
            "            assign wat_level_o = fifo_cnt + {{(CNT_WIDTH-1){1'b0}}, skid_valid};",
            "        end else begin : gen_std",
            "            assign fifo_rd_en  = rd_en_i && !fifo_empty;",
            "            assign dout_o      = fifo_dout;",
            "            assign empty_o     = fifo_empty;",
            "            assign full_o      = fifo_full;",
            "            assign wat_level_o = fifo_cnt;",
            "        end",
            "    endgenerate",
            "",
            "endmodule",
            "`resetall"
        ],
        "description": "Industrial Sync FIFO supporting both Standard and FWFT modes"
    },
    "Sync FIFO Instance": {
        "prefix": "fifo_inst (sync)",
        "body": [
            "sync_fifo_gen #( ",
            "    .FIFO_DEPTH ( ${1:16} ),",
            "    .FIFO_WIDTH ( ${2:32} ),",
            "    .FWFT_MODE  ( ${3:RTL_MODE_PASSIVE} )",
            ") u_${4:fifo_inst} (",
            "    .clk_i       ( ${5:clk_i} ),",
            "    .rst_ni      ( ${6:rst_ni} ),",
            "    // Write",
            "    .wr_en_i     ( ${7:wr_en} ),",
            "    .din_i       ( ${8:din} ),",
            "    .full_o      ( ${9:full} ),",
            "    // Read",
            "    .rd_en_i     ( ${10:rd_en} ),",
            "    .dout_o      ( ${11:dout} ),",
            "    .empty_o     ( ${12:empty} ),",
            "    // Status",
            "    .wat_level_o ( ${13:cnt} )",
            ");$0"
        ],
        "description": "Instantiation for sync_fifo_gen"
    }
}