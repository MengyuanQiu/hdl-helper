{
  "Pipeline Register": {
    "prefix": "pipe_reg",
    "body": [
      "// Pipeline Register Stage",
      "module pipe_reg #(",
      "    parameter int DATA_WIDTH = ${1:32},",
      "    parameter int NUM_STAGES = ${2:2}",
      ")(",
      "    input  logic                 clk,",
      "    input  logic                 rst_n,",
      "    input  logic                 valid_in,",
      "    input  logic [DATA_WIDTH-1:0] data_in,",
      "    output logic                 valid_out,",
      "    output logic [DATA_WIDTH-1:0] data_out",
      ");",
      "",
      "    // Pipeline registers",
      "    logic [NUM_STAGES-1:0][DATA_WIDTH-1:0] data_pipe;",
      "    logic [NUM_STAGES-1:0]       valid_pipe;",
      "",
      "    // Input stage",
      "    always_ff @(posedge clk or negedge rst_n) begin",
      "        if (!rst_n) begin",
      "            data_pipe[0] <= '0;",
      "            valid_pipe[0] <= 1'b0;",
      "        end else begin",
      "            data_pipe[0] <= data_in;",
      "            valid_pipe[0] <= valid_in;",
      "        end",
      "    end",
      "",
      "    // Middle stages",
      "    generate",
      "        for (genvar i = 1; i < NUM_STAGES; i++) begin : gen_pipe_stages",
      "            always_ff @(posedge clk or negedge rst_n) begin",
      "                if (!rst_n) begin",
      "                    data_pipe[i] <= '0;",
      "                    valid_pipe[i] <= 1'b0;",
      "                end else begin",
      "                    data_pipe[i] <= data_pipe[i-1];",
      "                    valid_pipe[i] <= valid_pipe[i-1];",
      "                end",
      "            end",
      "        end",
      "    endgenerate",
      "",
      "    // Output",
      "    assign data_out = data_pipe[NUM_STAGES-1];",
      "    assign valid_out = valid_pipe[NUM_STAGES-1];",
      "",
      "endmodule"
    ],
    "description": "Multi-stage pipeline register with valid signal"
  },
  "Pipeline Bubble": {
    "prefix": "pipe_bubble",
    "body": [
      "// Pipeline with Bubble Insertion",
      "always_ff @(posedge clk or negedge rst_n) begin",
      "    if (!rst_n) begin",
      "        ${1:stage_reg} <= '${2:0};",
      "        ${3:valid_reg} <= 1'b0;",
      "    end else if (${4:stall_condition}) begin",
      "        // Insert bubble (hold previous value, invalidate)",
      "        ${3:valid_reg} <= 1'b0;",
      "    end else if (${5:enable_condition}) begin",
      "        ${1:stage_reg} <= ${6:input_data};",
      "        ${3:valid_reg} <= 1'b1;",
      "    end else begin",
      "        ${3:valid_reg} <= 1'b0;",
      "    end",
      "end"
    ],
    "description": "Pipeline stage with bubble insertion for hazard handling"
  },
  "Forwarding Mux": {
    "prefix": "pipe_fwd",
    "body": [
      "// Pipeline Forwarding Multiplexer",
      "always_comb begin",
      "    ${1:output_data} = ${2:current_data};  // Default path",
      "    ",
      "    // Forwarding conditions",
      "    if (${3:fwd_condition_1}) begin",
      "        ${1:output_data} = ${4:bypass_data_1};",
      "    end else if (${5:fwd_condition_2}) begin",
      "        ${1:output_data} = ${6:bypass_data_2};",
      "    end",
      "end"
    ],
    "description": "Data forwarding logic for pipeline hazard resolution"
  }
}
