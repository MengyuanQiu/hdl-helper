{
  "Pipeline Stage": {
    "prefix": "pipe_stage",
    "body": [
      "// Pipeline Stage ${1:stage_name}",
      "always_ff @(posedge clk or negedge rst_n) begin",
      "    if (!rst_n) begin",
      "        ${2:stage_reg} <= '${3:0};",
      "    end else begin",
      "        ${2:stage_reg} <= ${4:prev_stage_output};",
      "    end",
      "end"
    ],
    "description": "Generate a pipeline stage with configurable width"
  },
  "Arbiter Round-Robin": {
    "prefix": "arb_rr",
    "body": [
      "// Round-Robin Arbiter",
      "module arbiter_rr #(",
      "    parameter int NUM_REQUESTS = ${1:4},",
      "    parameter int ID_WIDTH = $clog2(NUM_REQUESTS)",
      ")(",
      "    input  logic                 clk,",
      "    input  logic                 rst_n,",
      "    input  logic [NUM_REQUESTS-1:0] req,",
      "    output logic [NUM_REQUESTS-1:0] gnt,",
      "    output logic [ID_WIDTH-1:0]     grant_id",
      ");",
      "",
      "    logic [NUM_REQUESTS-1:0] mask;",
      "    logic [NUM_REQUESTS-1:0] masked_req;",
      "",
      "    // Priority encoder",
      "    always_comb begin",
      "        masked_req = req & mask;",
      "        if (masked_req != '0)",
      "            gnt = masked_req & ~(masked_req - 1'b1);",
      "        else begin",
      "            gnt = req & ~(req - 1'b1);",
      "        end",
      "    end",
      "",
      "    // Update priority",
      "    always_ff @(posedge clk or negedge rst_n) begin",
      "        if (!rst_n)",
      "            mask <= '1;",
      "        else if (gnt != '0)",
      "            mask <= {gnt[0], gnt[NUM_REQUESTS-1:1]};",
      "    end",
      "",
      "    // Grant ID encoder",
      "    always_comb begin",
      "        grant_id = '0;",
      "        for (int i = 0; i < NUM_REQUESTS; i++) begin",
      "            if (gnt[i])",
      "                grant_id = i[ID_WIDTH-1:0];",
      "        end",
      "    end",
      "",
      "endmodule"
    ],
    "description": "Round-robin arbiter for fair request arbitration"
  },
  "Crossbar Switch": {
    "prefix": "crossbar",
    "body": [
      "// Crossbar Switch Fabric",
      "module crossbar #(",
      "    parameter int NUM_INPUTS = ${1:4},",
      "    parameter int NUM_OUTPUTS = ${2:4},",
      "    parameter int DATA_WIDTH = ${3:32}",
      ")(",
      "    input  logic                  clk,",
      "    input  logic                  rst_n,",
      "    input  logic [NUM_INPUTS-1:0] valid_in,",
      "    input  logic [DATA_WIDTH-1:0] data_in [NUM_INPUTS],",
      "    input  logic [NUM_OUTPUTS-1:0] req_out,",
      "    output logic                  ready_out [NUM_INPUTS],",
      "    output logic                  valid_in_out [NUM_OUTPUTS],",
      "    output logic [DATA_WIDTH-1:0] data_out [NUM_OUTPUTS]",
      ");",
      "",
      "    // Routing logic",
      "    always_comb begin",
      "        for (int i = 0; i < NUM_OUTPUTS; i++) begin",
      "            valid_in_out[i] = '0;",
      "            data_out[i] = '0;",
      "            for (int j = 0; j < NUM_INPUTS; j++) begin",
      "                if (valid_in[j] && req_out[i][j]) begin",
      "                    valid_in_out[i] = valid_in[j];",
      "                    data_out[i] = data_in[j];",
      "                end",
      "            end",
      "        end",
      "    end",
      "",
      "    // Ready generation",
      "    always_comb begin",
      "        for (int i = 0; i < NUM_INPUTS; i++) begin",
      "            ready_out[i] = '1;",
      "        end",
      "    end",
      "",
      "endmodule"
    ],
    "description": "Crossbar switch fabric for multi-master interconnect"
  },
  "Priority Encoder": {
    "prefix": "pri_enc",
    "body": [
      "// Priority Encoder",
      "module priority_encoder #(",
      "    parameter int WIDTH = ${1:8},",
      "    parameter int OUT_WIDTH = $clog2(WIDTH)",
      ")(",
      "    input  logic [WIDTH-1:0]    in,",
      "    output logic [OUT_WIDTH-1:0] out,",
      "    output logic                valid",
      ");",
      "",
      "    always_comb begin",
      "        out = '0;",
      "        valid = '0;",
      "        for (int i = WIDTH-1; i >= 0; i--) begin",
      "            if (in[i]) begin",
      "                out = i[OUT_WIDTH-1:0];",
      "                valid = 1'b1;",
      "                break;",
      "            end",
      "        end",
      "    end",
      "",
      "endmodule"
    ],
    "description": "Priority encoder with configurable width"
  },
  "One-Hot to Binary": {
    "prefix": "oh2bin",
    "body": [
      "// One-Hot to Binary Encoder",
      "module onehot_to_binary #(",
      "    parameter int OH_WIDTH = ${1:8},",
      "    parameter int BIN_WIDTH = $clog2(OH_WIDTH)",
      ")(",
      "    input  logic [OH_WIDTH-1:0] oh,",
      "    output logic [BIN_WIDTH-1:0] bin",
      ");",
      "",
      "    always_comb begin",
      "        bin = '0;",
      "        for (int i = 0; i < OH_WIDTH; i++) begin",
      "            if (oh[i])",
      "                bin = i[BIN_WIDTH-1:0];",
      "        end",
      "    end",
      "",
      "endmodule"
    ],
    "description": "Convert one-hot encoding to binary"
  }
}
