{
  "Template RV stage module": {
    "prefix": "tpl.rtl.rv.stage",
    "body": [
      "module ${1:rv_stage} #(",
      "    parameter int W = ${2:32}",
      ") (",
      "    input  logic         clk_i,",
      "    input  logic         rst_ni,",
      "    input  logic         in_valid_i,",
      "    output logic         in_ready_o,",
      "    input  logic [W-1:0] in_data_i,",
      "    output logic         out_valid_o,",
      "    input  logic         out_ready_i,",
      "    output logic [W-1:0] out_data_o",
      ");",
      "",
      "    logic             v_q;",
      "    logic [W-1:0]    d_q;",
      "",
      "    assign in_ready_o  = !v_q || out_ready_i;",
      "    assign out_valid_o = v_q;",
      "    assign out_data_o  = d_q;",
      "",
      "    always_ff @(posedge clk_i or negedge rst_ni) begin",
      "        if (!rst_ni) begin",
      "            v_q <= 1'b0;",
      "        end else if (in_ready_o) begin",
      "            v_q <= in_valid_i;",
      "            d_q <= in_data_i;",
      "        end",
      "    end",
      "",
      "endmodule : ${1:rv_stage}$0"
    ],
    "description": "Ready/valid stage template based on rtl.rv.slice"
  },
  "Template RV skid stage module": {
    "prefix": "tpl.rtl.rv.skid_stage",
    "body": [
      "module ${1:rv_skid_stage} #(",
      "    parameter int W = ${2:32}",
      ") (",
      "    input  logic         clk_i,",
      "    input  logic         rst_ni,",
      "    input  logic         in_valid_i,",
      "    output logic         in_ready_o,",
      "    input  logic [W-1:0] in_data_i,",
      "    output logic         out_valid_o,",
      "    input  logic         out_ready_i,",
      "    output logic [W-1:0] out_data_o",
      ");",
      "",
      "    logic          skid_v_q;",
      "    logic [W-1:0] skid_d_q;",
      "",
      "    assign in_ready_o  = !skid_v_q || out_ready_i;",
      "    assign out_valid_o = in_valid_i || skid_v_q;",
      "    assign out_data_o  = skid_v_q ? skid_d_q : in_data_i;",
      "",
      "    always_ff @(posedge clk_i or negedge rst_ni) begin",
      "        if (!rst_ni) begin",
      "            skid_v_q <= 1'b0;",
      "        end else begin",
      "            if (in_valid_i && !out_ready_i && !skid_v_q) begin",
      "                skid_v_q <= 1'b1;",
      "                skid_d_q <= in_data_i;",
      "            end else if (out_ready_i) begin",
      "                skid_v_q <= 1'b0;",
      "            end",
      "        end",
      "    end",
      "",
      "endmodule : ${1:rv_skid_stage}$0"
    ],
    "description": "Ready/valid skid template based on rtl.rv.skid"
  },
  "Template RV demux2 module": {
    "prefix": "tpl.rtl.rv.demux2",
    "body": [
      "module ${1:rv_demux2} #(",
      "    parameter int W = ${2:32}",
      ") (",
      "    input  logic         sel_i,",
      "    input  logic         in_valid_i,",
      "    output logic         in_ready_o,",
      "    input  logic [W-1:0] in_data_i,",
      "    output logic         out0_valid_o,",
      "    input  logic         out0_ready_i,",
      "    output logic [W-1:0] out0_data_o,",
      "    output logic         out1_valid_o,",
      "    input  logic         out1_ready_i,",
      "    output logic [W-1:0] out1_data_o",
      ");",
      "",
      "    always_comb begin",
      "        out0_valid_o = 1'b0;",
      "        out1_valid_o = 1'b0;",
      "        out0_data_o  = '0;",
      "        out1_data_o  = '0;",
      "        in_ready_o   = 1'b0;",
      "        case (sel_i)",
      "            1'b0: begin",
      "                out0_valid_o = in_valid_i;",
      "                out0_data_o  = in_data_i;",
      "                in_ready_o   = out0_ready_i;",
      "            end",
      "            default: begin",
      "                out1_valid_o = in_valid_i;",
      "                out1_data_o  = in_data_i;",
      "                in_ready_o   = out1_ready_i;",
      "            end",
      "        endcase",
      "    end",
      "",
      "endmodule : ${1:rv_demux2}$0"
    ],
    "description": "Ready/valid demux template based on rtl.rv.demux"
  }
}
