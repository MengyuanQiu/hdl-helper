{
  "Template FSM 3-segment controller": {
    "prefix": "tpl.rtl.fsm.ctrl.3seg",
    "body": [
      "module ${1:fsm_ctrl} (",
      "    input  logic clk_i,",
      "    input  logic rst_ni,",
      "    input  logic start_i,",
      "    input  logic done_i,",
      "    output logic busy_o",
      ");",
      "",
      "    typedef enum logic [1:0] {",
      "        ST_IDLE,",
      "        ST_BUSY,",
      "        ST_DONE",
      "    } state_t;",
      "",
      "    state_t state_q, state_d;",
      "",
      "    always_ff @(posedge clk_i or negedge rst_ni) begin",
      "        if (!rst_ni) begin",
      "            state_q <= ST_IDLE;",
      "        end else begin",
      "            state_q <= state_d;",
      "        end",
      "    end",
      "",
      "    always_comb begin",
      "        state_d = state_q;",
      "        unique case (state_q)",
      "            ST_IDLE: if (start_i) state_d = ST_BUSY;",
      "            ST_BUSY: if (done_i)  state_d = ST_DONE;",
      "            ST_DONE:              state_d = ST_IDLE;",
      "            default:              state_d = ST_IDLE;",
      "        endcase",
      "    end",
      "",
      "    always_comb begin",
      "        busy_o = 1'b0;",
      "        case (state_q)",
      "            ST_BUSY: busy_o = 1'b1;",
      "            default: ;",
      "        endcase",
      "    end",
      "",
      "endmodule : ${1:fsm_ctrl}$0"
    ],
    "description": "Controller template based on rtl.fsm.3seg and rtl.fsm.2seg.unique style"
  },
  "Template FSM onehot controller": {
    "prefix": "tpl.rtl.fsm.ctrl.onehot",
    "body": [
      "module ${1:fsm_onehot_ctrl} (",
      "    input  logic clk_i,",
      "    input  logic rst_ni,",
      "    input  logic start_i,",
      "    input  logic done_i,",
      "    output logic busy_o",
      ");",
      "",
      "    localparam int STATE_W = 3;",
      "    typedef enum logic [STATE_W-1:0] {",
      "        ST_IDLE = 3'b001,",
      "        ST_BUSY = 3'b010,",
      "        ST_DONE = 3'b100",
      "    } state_t;",
      "",
      "    (* fsm_encoding = \"one_hot\" *) state_t state_q, state_d;",
      "",
      "    always_ff @(posedge clk_i or negedge rst_ni) begin",
      "        if (!rst_ni) begin",
      "            state_q <= ST_IDLE;",
      "        end else begin",
      "            state_q <= state_d;",
      "        end",
      "    end",
      "",
      "    always_comb begin",
      "        state_d = '0;",
      "        unique case (1'b1)",
      "            state_q[0]: state_d = start_i ? ST_BUSY : ST_IDLE;",
      "            state_q[1]: state_d = done_i  ? ST_DONE : ST_BUSY;",
      "            state_q[2]: state_d = ST_IDLE;",
      "            default:    state_d = ST_IDLE;",
      "        endcase",
      "    end",
      "",
      "    assign busy_o = state_q[1];",
      "",
      "endmodule : ${1:fsm_onehot_ctrl}$0"
    ],
    "description": "Onehot controller template based on rtl.fsm.onehot"
  },
  "Template FSM illegal recover with flag": {
    "prefix": "tpl.rtl.fsm.recover.flag",
    "body": [
      "always_comb begin",
      "    ${1:state_d}         = ${2:state_q};",
      "    ${3:illegal_state_o} = 1'b0;",
      "    if (!(${2:state_q} inside {${4:ST_IDLE}, ${5:ST_BUSY}, ${6:ST_DONE}})) begin",
      "        ${1:state_d}         = ${4:ST_IDLE};",
      "        ${3:illegal_state_o} = 1'b1;",
      "    end",
      "end$0"
    ],
    "description": "Illegal-state recovery template reused from rtl.fsm.illegal_recover.flag"
  }
}
