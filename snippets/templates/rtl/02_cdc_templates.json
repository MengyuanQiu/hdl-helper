{
  "Template CDC bit synchronizer module": {
    "prefix": "tpl.rtl.cdc.bit_sync",
    "body": [
      "module ${1:cdc_bit_sync} (",
      "    input  logic clk_dst_i,",
      "    input  logic rst_dst_ni,",
      "    input  logic async_sig_i,",
      "    output logic sync_sig_o",
      ");",
      "",
      "    logic async_sig_meta_q, async_sig_sync_q;",
      "",
      "    (* ASYNC_REG = \"TRUE\" *)",
      "    always_ff @(posedge clk_dst_i or negedge rst_dst_ni) begin",
      "        if (!rst_dst_ni) begin",
      "            async_sig_meta_q <= 1'b0;",
      "            async_sig_sync_q <= 1'b0;",
      "        end else begin",
      "            async_sig_meta_q <= async_sig_i;",
      "            async_sig_sync_q <= async_sig_meta_q;",
      "        end",
      "    end",
      "",
      "    assign sync_sig_o = async_sig_sync_q;",
      "",
      "endmodule : ${1:cdc_bit_sync}$0"
    ],
    "description": "Single-bit CDC template based on rtl.cdc.2ff"
  },
  "Template CDC reset bridge module": {
    "prefix": "tpl.rtl.cdc.reset_bridge",
    "body": [
      "module ${1:cdc_reset_bridge} #(",
      "    parameter int SYNC_STAGES = ${2:2}",
      ") (",
      "    input  logic clk_i,",
      "    input  logic rst_async_ni,",
      "    output logic rst_sync_ni",
      ");",
      "",
      "    logic [SYNC_STAGES-1:0] rst_sync_q;",
      "",
      "    always_ff @(posedge clk_i or negedge rst_async_ni) begin",
      "        if (!rst_async_ni) begin",
      "            rst_sync_q <= '0;",
      "        end else begin",
      "            rst_sync_q <= {rst_sync_q[SYNC_STAGES-2:0], 1'b1};",
      "        end",
      "    end",
      "",
      "    assign rst_sync_ni = rst_sync_q[SYNC_STAGES-1];",
      "",
      "endmodule : ${1:cdc_reset_bridge}$0"
    ],
    "description": "Async-assert sync-deassert reset template based on rtl.reset.release_sync"
  },
  "Template CDC reqack event bridge": {
    "prefix": "tpl.rtl.cdc.reqack_bridge",
    "body": [
      "module ${1:cdc_reqack_bridge} (",
      "    input  logic clk_src_i,",
      "    input  logic rst_src_ni,",
      "    input  logic clk_dst_i,",
      "    input  logic rst_dst_ni,",
      "    input  logic req_pulse_i,",
      "    output logic req_dst_pulse_o,",
      "    output logic busy_src_o",
      ");",
      "",
      "    logic req_src_q;",
      "    logic req_dst_meta_q, req_dst_sync_q, req_dst_sync_d_q;",
      "    logic ack_dst_q;",
      "    logic ack_src_meta_q, ack_src_sync_q;",
      "",
      "    always_ff @(posedge clk_src_i or negedge rst_src_ni) begin",
      "        if (!rst_src_ni) begin",
      "            req_src_q <= 1'b0;",
      "        end else if (req_pulse_i) begin",
      "            req_src_q <= 1'b1;",
      "        end else if (ack_src_sync_q) begin",
      "            req_src_q <= 1'b0;",
      "        end",
      "    end",
      "",
      "    (* ASYNC_REG = \"TRUE\" *)",
      "    always_ff @(posedge clk_dst_i or negedge rst_dst_ni) begin",
      "        if (!rst_dst_ni) begin",
      "            req_dst_meta_q   <= 1'b0;",
      "            req_dst_sync_q   <= 1'b0;",
      "            req_dst_sync_d_q <= 1'b0;",
      "        end else begin",
      "            req_dst_meta_q   <= req_src_q;",
      "            req_dst_sync_q   <= req_dst_meta_q;",
      "            req_dst_sync_d_q <= req_dst_sync_q;",
      "        end",
      "    end",
      "",
      "    assign req_dst_pulse_o = req_dst_sync_q & ~req_dst_sync_d_q;",
      "",
      "    always_ff @(posedge clk_dst_i or negedge rst_dst_ni) begin",
      "        if (!rst_dst_ni) begin",
      "            ack_dst_q <= 1'b0;",
      "        end else begin",
      "            ack_dst_q <= req_dst_pulse_o;",
      "        end",
      "    end",
      "",
      "    (* ASYNC_REG = \"TRUE\" *)",
      "    always_ff @(posedge clk_src_i or negedge rst_src_ni) begin",
      "        if (!rst_src_ni) begin",
      "            ack_src_meta_q <= 1'b0;",
      "            ack_src_sync_q <= 1'b0;",
      "        end else begin",
      "            ack_src_meta_q <= ack_dst_q;",
      "            ack_src_sync_q <= ack_src_meta_q;",
      "        end",
      "    end",
      "",
      "    assign busy_src_o = req_src_q;",
      "    // TODO: Keep source pulse rate low enough for destination capture.",
      "",
      "endmodule : ${1:cdc_reqack_bridge}$0"
    ],
    "description": "Req/ack event crossing template based on rtl.cdc.reqack.full"
  }
}
