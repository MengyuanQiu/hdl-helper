{
	"RTL mux 2to1": {
		"prefix": "rtl.mux.basic",
		"body": "assign ${1:y_o} = ${2:sel_i} ? ${3:b_i} : ${4:a_i};$0",
		"description": "2:1 mux"
	},
	"RTL mux case": {
		"prefix": "rtl.mux.case",
		"body": [
			"always_comb begin",
			"    ${1:data_o} = '0;",
			"    case (${2:sel_i})",
			"        ${3:0}: ${1:data_o} = ${4:in0_i};",
			"        ${5:1}: ${1:data_o} = ${6:in1_i};",
			"        default: ;",
			"    endcase",
			"end$0"
		],
		"description": "Case-based 2-to-1 mux template"
	},
	"RTL demux basic": {
		"prefix": "rtl.demux.basic",
		"body": [
			"always_comb begin",
			"    ${1:out0_o} = '0;",
			"    ${2:out1_o} = '0;",
			"    case (${3:sel_i})",
			"        1'b0: ${1:out0_o} = ${4:in_i};",
			"        default: ${2:out1_o} = ${4:in_i};",
			"    endcase",
			"end$0"
		],
		"description": "1-to-2 demux"
	},
	"RTL priority encoder": {
		"prefix": "rtl.enc.priority",
		"body": [
			"always_comb begin",
			"    ${1:valid_o} = 1'b0;",
			"    ${2:idx_o}   = '0;",
			"    for (int i = ${3:WIDTH}-1; i >= 0; i--) begin",
			"        if (${4:req_i}[i]) begin",
			"            ${1:valid_o} = 1'b1;",
			"            ${2:idx_o}   = i[$clog2(${3:WIDTH})-1:0];",
			"            break;",
			"        end",
			"    end",
			"end$0"
		],
		"description": "Priority encoder"
	},
	"RTL onehot to binary": {
		"prefix": "rtl.enc.onehot2bin",
		"body": [
			"always_comb begin",
			"    ${1:bin_o} = '0;",
			"    for (int i = 0; i < ${2:WIDTH}; i++) begin",
			"        if (${3:onehot_i}[i]) ${1:bin_o} = i[$clog2(${2:WIDTH})-1:0];",
			"    end",
			"end$0"
		],
		"description": "One-hot to binary encoder without explicit valid output"
	},
	"RTL onehot to binary with valid": {
		"prefix": "rtl.enc.onehot2bin.valid",
		"body": [
			"always_comb begin",
			"    ${1:bin_o}   = '0;",
			"    ${2:valid_o} = |${3:onehot_i};",
			"    for (int i = 0; i < ${4:WIDTH}; i++) begin",
			"        if (${3:onehot_i}[i]) ${1:bin_o} = i[$clog2(${4:WIDTH})-1:0];",
			"    end",
			"end$0"
		],
		"description": "One-hot to binary encoder with valid output"
	},
	"RTL binary to onehot": {
		"prefix": "rtl.dec.bin2onehot",
		"body": [
			"always_comb begin",
			"    ${1:onehot_o} = '0;",
			"    if (${2:bin_i} < ${3:WIDTH}) begin",
			"        ${1:onehot_o}[${2:bin_i}] = 1'b1;",
			"    end",
			"end$0"
		],
		"description": "Binary to one-hot decoder"
	},
	"RTL gray to binary": {
		"prefix": "rtl.gray2bin",
		"body": [
			"function automatic logic [${1:W}-1:0] ${2:gray2bin}(input logic [${1:W}-1:0] ${3:gray_i});",
			"    logic [${1:W}-1:0] ${4:bin_v};",
			"    ${4:bin_v}[${1:W}-1] = ${3:gray_i}[${1:W}-1];",
			"    for (int i = ${1:W}-2; i >= 0; i--) begin",
			"        ${4:bin_v}[i] = ${4:bin_v}[i+1] ^ ${3:gray_i}[i];",
			"    end",
			"    return ${4:bin_v};",
			"endfunction$0"
		],
		"description": "Gray to binary conversion"
	},
	"RTL binary to gray": {
		"prefix": "rtl.bin2gray",
		"body": [
			"function automatic logic [${1:W}-1:0] ${2:bin2gray}(input logic [${1:W}-1:0] ${3:bin_i});",
			"    return ${3:bin_i} ^ (${3:bin_i} >> 1);",
			"endfunction$0"
		],
		"description": "Binary to gray conversion"
	}
}
