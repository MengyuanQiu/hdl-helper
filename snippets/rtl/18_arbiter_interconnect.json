{
	"RTL round-robin arbiter": {
		"prefix": "rtl.arb.rr",
		"body": [
			"logic [${1:N}-1:0] ${2:req_mask_q};",
			"logic [${1:N}-1:0] ${3:req_masked_w};",
			"",
			"assign ${3:req_masked_w} = ${4:req_i} & ${2:req_mask_q};",
			"assign ${5:gnt_o} = (${3:req_masked_w} != '0) ? (${3:req_masked_w} & -${3:req_masked_w}) : (${4:req_i} & -${4:req_i});",
			"",
			"always_ff @(posedge ${6:clk_i} or negedge ${7:rst_ni}) begin",
			"    if (!${7:rst_ni}) begin",
			"        ${2:req_mask_q} <= '1;",
			"    end else if (${5:gnt_o} != '0) begin",
			"        ${2:req_mask_q} <= {${5:gnt_o}[0], ${5:gnt_o}[${1:N}-1:1]};",
			"    end",
			"end$0"
		],
		"description": "Round-robin arbiter core logic with onehot grant"
	},
	"RTL fixed-priority arbiter": {
		"prefix": "rtl.arb.fixed",
		"body": "assign ${1:gnt_o} = ${2:req_i} & -${2:req_i};$0",
		"description": "Fixed-priority arbiter with LSB-highest onehot grant"
	},
	"RTL masked arbiter": {
		"prefix": "rtl.arb.mask",
		"body": [
			"logic [${1:N}-1:0] ${2:req_eff_w};",
			"assign ${2:req_eff_w} = ${3:req_i} & ${4:mask_i};",
			"assign ${5:gnt_o}     = ${2:req_eff_w} & -${2:req_eff_w};$0"
		],
		"description": "Maskable fixed-priority arbiter with LSB-highest onehot grant"
	},
	"RTL crossbar shell": {
		"prefix": "rtl.xbar.shell",
		"body": [
			"module ${1:xbar_shell} #(",
			"    parameter int M = ${2:2},",
			"    parameter int S = ${3:2},",
			"    parameter int W = ${4:32}",
			") (",
			"    input  logic [M-1:0]     m_valid_i,",
			"    output logic [M-1:0]     m_ready_o,",
			"    input  logic [M-1:0][W-1:0] m_data_i,",
			"    output logic [S-1:0]     s_valid_o,",
			"    input  logic [S-1:0]     s_ready_i,",
			"    output logic [S-1:0][W-1:0] s_data_o",
			");",
			"    // TODO: arbitration + route select + backpressure",
			"    $0",
			"endmodule : ${1:xbar_shell}"
		],
		"description": "Crossbar/interconnect skeleton"
	},
	"RTL address decode": {
		"prefix": "rtl.addr.decode",
		"body": [
			"always_comb begin",
			"    ${1:sel_o} = '0;",
			"    unique casez (${2:addr_i})",
			"        ${3:32'h0000_????}: ${1:sel_o}[0] = 1'b1;",
			"        ${4:32'h0001_????}: ${1:sel_o}[1] = 1'b1;",
			"        default: ;",
			"    endcase",
			"end$0"
		],
		"description": "Address region decode"
	},
	"RTL request-grant matrix shell": {
		"prefix": "rtl.req_gnt.matrix",
		"body": [
			"logic [${1:M}-1:0][${2:S}-1:0] ${3:req_mat_w};",
			"logic [${1:M}-1:0][${2:S}-1:0] ${4:gnt_mat_w};",
			"",
			"// TODO: build request matrix per route and apply per-slave arbiter",
			"$0"
		],
		"description": "Request/grant matrix scaffold for interconnect"
	}
}
