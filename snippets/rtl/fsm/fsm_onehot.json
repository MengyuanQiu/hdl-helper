{
    "One-Hot FSM Template": {
        "prefix": "fsm_onehot",
        "body": [
            "// Module: ${5:fsm_name}",
            "// Purpose: Highly optimized One-Hot FSM Skeleton",
            "// Trigger: fsm_onehot",
            "",
            "// --- 1. State Definition ---",
            "localparam int STATE_W = ${1:3};",
            "typedef enum logic [STATE_W-1:0] {",
            "    ${2:IDLE}   = ${1:3}'b001,",
            "    ${3:ACTIVE} = ${1:3}'b010,",
            "    ${4:DONE}   = ${1:3}'b100",
            "} ${6:state}_t;",
            "",
            "(* fsm_encoding = \"one_hot\" *) ${6:state}_t current_state, next_state;",
            "",
            "// --- 2. Sequential State Register ---",
            "always_ff @(posedge clk or negedge rst_n) begin",
            "    if (!rst_n) current_state <= ${2:IDLE};",
            "    else        current_state <= next_state;",
            "end",
            "",
            "// --- 3. Parallel Next State Evaluator ---",
            "always_comb begin",
            "    next_state = '0;",
            "    // Safe case matching for strict checking natively",
            "    unique case (1'b1)",
            "        current_state[0]: begin // ${2:IDLE}",
            "            if (${7:start_condition}) next_state = ${3:ACTIVE};",
            "            else                      next_state = ${2:IDLE};",
            "        end",
            "        current_state[1]: begin // ${3:ACTIVE}",
            "            if (${8:done_condition})  next_state = ${4:DONE};",
            "            else                      next_state = ${3:ACTIVE};",
            "        end",
            "        current_state[2]: begin // ${4:DONE}",
            "            next_state = ${2:IDLE};",
            "        end",
            "        default: next_state = ${2:IDLE};",
            "    endcase",
            "end",
            "",
            "// --- 4. Parallel Combinational / Registered Output ---",
            "always_ff @(posedge clk or negedge rst_n) begin",
            "    if (!rst_n) ${9:out_signal} <= 1'b0;",
            "    else        ${9:out_signal} <= (next_state == ${3:ACTIVE});",
            "end$0"
        ],
        "description": "High Performance One-Hot Encoded FSM"
    }
}
