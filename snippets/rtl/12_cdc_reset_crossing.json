{
	"RTL CDC 2FF synchronizer": {
		"prefix": "rtl.cdc.2ff",
		"body": [
			"logic ${1:async_sig_meta_q}, ${1:async_sig_sync_q};",
			"",
			"(* ASYNC_REG = \"TRUE\" *)",
			"always_ff @(posedge ${2:clk_dst_i} or negedge ${3:rst_dst_ni}) begin",
			"    if (!${3:rst_dst_ni}) begin",
			"        ${1:async_sig_meta_q} <= 1'b0;",
			"        ${1:async_sig_sync_q} <= 1'b0;",
			"    end else begin",
			"        ${1:async_sig_meta_q} <= ${4:async_sig_i};",
			"        ${1:async_sig_sync_q} <= ${1:async_sig_meta_q};",
			"    end",
			"end$0"
		],
		"description": "Single-bit only CDC two-flop synchronizer; do not use directly for multi-bit buses"
	},
	"RTL CDC pulse synchronizer": {
		"prefix": "rtl.cdc.pulse",
		"body": [
			"logic ${1:tgl_src_q}, ${2:tgl_meta_q}, ${3:tgl_sync_q}, ${4:tgl_sync_d_q};",
			"",
			"always_ff @(posedge ${5:clk_src_i} or negedge ${6:rst_src_ni}) begin",
			"    if (!${6:rst_src_ni}) begin",
			"        ${1:tgl_src_q} <= 1'b0;",
			"    end else if (${7:pulse_src_i}) begin",
			"        ${1:tgl_src_q} <= ~${1:tgl_src_q};",
			"    end",
			"end",
			"",
			"(* ASYNC_REG = \"TRUE\" *)",
			"always_ff @(posedge ${8:clk_dst_i} or negedge ${9:rst_dst_ni}) begin",
			"    if (!${9:rst_dst_ni}) begin",
			"        ${2:tgl_meta_q}   <= 1'b0;",
			"        ${3:tgl_sync_q}   <= 1'b0;",
			"        ${4:tgl_sync_d_q} <= 1'b0;",
			"    end else begin",
			"        ${2:tgl_meta_q}   <= ${1:tgl_src_q};",
			"        ${3:tgl_sync_q}   <= ${2:tgl_meta_q};",
			"        ${4:tgl_sync_d_q} <= ${3:tgl_sync_q};",
			"    end",
			"end",
			"",
			"assign ${10:pulse_dst_o} = ${3:tgl_sync_q} ^ ${4:tgl_sync_d_q};$0"
		],
		"description": "Pulse crossing with toggle and edge detect; source pulse rate must allow destination capture"
	},
	"RTL CDC request-ack source": {
		"prefix": "rtl.cdc.reqack.src",
		"body": [
			"// Source side intent signal",
			"logic ${1:req_src_q};",
			"logic ${2:ack_src_sync_q};",
			"",
			"always_ff @(posedge ${3:clk_src_i} or negedge ${4:rst_src_ni}) begin",
			"    if (!${4:rst_src_ni}) begin",
			"        ${1:req_src_q} <= 1'b0;",
			"    end else if (${5:req_pulse_i}) begin",
			"        ${1:req_src_q} <= 1'b1;",
			"    end else if (${2:ack_src_sync_q}) begin",
			"        ${1:req_src_q} <= 1'b0;",
			"    end",
			"end$0"
		],
		"description": "Source-side request/ack CDC skeleton"
	},
	"RTL CDC request-ack full": {
		"prefix": "rtl.cdc.reqack.full",
		"body": [
			"logic ${1:req_src_q};",
			"logic ${2:req_dst_meta_q}, ${3:req_dst_sync_q}, ${4:req_dst_sync_d_q};",
			"logic ${5:ack_dst_q};",
			"logic ${6:ack_src_meta_q}, ${7:ack_src_sync_q};",
			"",
			"always_ff @(posedge ${8:clk_src_i} or negedge ${9:rst_src_ni}) begin",
			"    if (!${9:rst_src_ni}) begin",
			"        ${1:req_src_q} <= 1'b0;",
			"    end else if (${10:req_pulse_i}) begin",
			"        ${1:req_src_q} <= 1'b1;",
			"    end else if (${7:ack_src_sync_q}) begin",
			"        ${1:req_src_q} <= 1'b0;",
			"    end",
			"end",
			"",
			"(* ASYNC_REG = \"TRUE\" *)",
			"always_ff @(posedge ${11:clk_dst_i} or negedge ${12:rst_dst_ni}) begin",
			"    if (!${12:rst_dst_ni}) begin",
			"        ${2:req_dst_meta_q}   <= 1'b0;",
			"        ${3:req_dst_sync_q}   <= 1'b0;",
			"        ${4:req_dst_sync_d_q} <= 1'b0;",
			"    end else begin",
			"        ${2:req_dst_meta_q}   <= ${1:req_src_q};",
			"        ${3:req_dst_sync_q}   <= ${2:req_dst_meta_q};",
			"        ${4:req_dst_sync_d_q} <= ${3:req_dst_sync_q};",
			"    end",
			"end",
			"",
			"assign ${13:req_dst_pulse_o} = ${3:req_dst_sync_q} & ~${4:req_dst_sync_d_q};",
			"",
			"always_ff @(posedge ${11:clk_dst_i} or negedge ${12:rst_dst_ni}) begin",
			"    if (!${12:rst_dst_ni}) begin",
			"        ${5:ack_dst_q} <= 1'b0;",
			"    end else begin",
			"        ${5:ack_dst_q} <= ${13:req_dst_pulse_o};",
			"    end",
			"end",
			"",
			"(* ASYNC_REG = \"TRUE\" *)",
			"always_ff @(posedge ${8:clk_src_i} or negedge ${9:rst_src_ni}) begin",
			"    if (!${9:rst_src_ni}) begin",
			"        ${6:ack_src_meta_q} <= 1'b0;",
			"        ${7:ack_src_sync_q} <= 1'b0;",
			"    end else begin",
			"        ${6:ack_src_meta_q} <= ${5:ack_dst_q};",
			"        ${7:ack_src_sync_q} <= ${6:ack_src_meta_q};",
			"    end",
			"end",
			"",
			"assign ${14:busy_src_o} = ${1:req_src_q};",
			"// TODO: Source pulse rate must be low enough to avoid event loss in this skeleton.$0"
		],
		"description": "Bidirectional req/ack CDC skeleton with synced return ack"
	},
	"RTL reset release synchronizer": {
		"prefix": "rtl.reset.release_sync",
		"body": [
			"localparam int ${1:SYNC_STAGES} = ${2:2};",
			"// NOTE: SYNC_STAGES should be >= 2",
			"logic [${1:SYNC_STAGES}-1:0] ${3:rst_sync_q};",
			"",
			"always_ff @(posedge ${4:clk_i} or negedge ${5:rst_async_ni}) begin",
			"    if (!${5:rst_async_ni}) begin",
			"        ${3:rst_sync_q} <= '0;",
			"    end else begin",
			"        ${3:rst_sync_q} <= {${3:rst_sync_q}[${1:SYNC_STAGES}-2:0], 1'b1};",
			"    end",
			"end",
			"",
			"assign ${6:rst_sync_ni} = ${3:rst_sync_q}[${1:SYNC_STAGES}-1];$0"
		],
		"description": "Async assert, sync deassert reset synchronizer (SYNC_STAGES >= 2)"
	},
	"RTL edge detector": {
		"prefix": "rtl.edge.detect",
		"body": [
			"logic ${1:sig_d_q};",
			"",
			"always_ff @(posedge ${2:clk_i} or negedge ${3:rst_ni}) begin",
			"    if (!${3:rst_ni}) begin",
			"        ${1:sig_d_q} <= 1'b0;",
			"    end else begin",
			"        ${1:sig_d_q} <= ${4:sig_i};",
			"    end",
			"end",
			"",
			"assign ${5:rise_o} = ${4:sig_i} & ~${1:sig_d_q};",
			"assign ${6:fall_o} = ~${4:sig_i} & ${1:sig_d_q};",
			"assign ${7:edge_o} = ${4:sig_i} ^ ${1:sig_d_q};$0"
		],
		"description": "Rising/falling/any-edge detect"
	},
	"RTL pulse stretcher": {
		"prefix": "rtl.pulse.stretch",
		"body": [
			"logic [${1:CNT_W}-1:0] ${2:stretch_cnt_q};",
			"",
			"always_ff @(posedge ${4:clk_i} or negedge ${5:rst_ni}) begin",
			"    if (!${5:rst_ni}) begin",
			"        ${2:stretch_cnt_q} <= '0;",
			"    end else if (${6:pulse_i}) begin",
			"        ${2:stretch_cnt_q} <= ${3:STRETCH_LEN};",
			"    end else if (${2:stretch_cnt_q} != '0) begin",
			"        ${2:stretch_cnt_q} <= ${2:stretch_cnt_q} - 1'b1;",
			"    end",
			"end",
			"",
			"assign ${7:pulse_stretched_o} = (${2:stretch_cnt_q} != '0);$0"
		],
		"description": "Stretch a narrow pulse for N cycles"
	}
}
