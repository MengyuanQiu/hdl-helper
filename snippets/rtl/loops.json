{
    "Generate For Loop": {
        "prefix": "rtl_generate_for",
        "body": [
            "// Generate Block: ${3:purpose}",
            "generate",
            "    for (genvar ${1:i} = 0; ${1:i} < ${2:N}; ${1:i}++) begin : gen_${1:i}",
            "        $0",
            "    end",
            "endgenerate"
        ],
        "description": "SystemVerilog Generate For Loop with synchronized iterator variables"
    },
    "Standard For Loop": {
        "prefix": "rtl_for",
        "body": [
            "for (int ${1:i} = 0; ${1:i} < ${2:limit}; ${1:i}++) begin",
            "    $0",
            "end"
        ],
        "description": "Standard For block with synchronized iterator"
    },
    "While Loop": {
        "prefix": "rtl_while",
        "body": [
            "while (${1:condition}) begin",
            "    $0",
            "end"
        ],
        "description": "Standard While block"
    }
}
