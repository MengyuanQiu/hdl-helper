{
    "Create Clock": {
        "prefix": "sdc_create_clock",
        "body": [
            "create_clock -name ${1:clk} -period ${2:10.0} [get_ports {${3:clk_i}}]$0"
        ],
        "description": "Create a primary timing clock (SDC standard)"
    },
    "Create Generated Clock": {
        "prefix": "sdc_generated_clock",
        "body": [
            "create_generated_clock -name ${1:clk_div2} \\",
            "    -source [get_pins ${2:u_pll/clk_in}] \\",
            "    -divide_by ${3:2} \\",
            "    [get_pins ${4:u_pll/clk_out}]$0"
        ],
        "description": "Create a generated derived clock"
    },
    "Set Input Delay": {
        "prefix": "sdc_input_delay",
        "body": [
            "set_input_delay -clock [get_clocks ${1:clk}] -max ${2:2.0} [get_ports ${3:data_in}]",
            "set_input_delay -clock [get_clocks ${1:clk}] -min ${4:0.5} [get_ports ${3:data_in}]$0"
        ],
        "description": "Standard Input Delay definitions"
    },
    "Set Output Delay": {
        "prefix": "sdc_output_delay",
        "body": [
            "set_output_delay -clock [get_clocks ${1:clk}] -max ${2:2.0} [get_ports ${3:data_out}]",
            "set_output_delay -clock [get_clocks ${1:clk}] -min ${4:0.5} [get_ports ${3:data_out}]$0"
        ],
        "description": "Standard Output Delay definitions"
    },
    "Set False Path": {
        "prefix": "sdc_false_path",
        "body": [
            "set_false_path -from [get_cells ${1:async_reg_src}] -to [get_cells ${2:async_reg_dst}]$0"
        ],
        "description": "Declare an asynchronous false path"
    }
}
