{
	"XDC create clock": {
		"prefix": "xdc.clock.create",
		"body": [
			"create_clock -period ${1:10.000} -name ${2:sys_clk} -waveform {0.000 ${3:5.000}} [get_ports ${4:clk_i}]$0"
		],
		"description": "Create primary XDC clock"
	},
	"XDC create generated clock": {
		"prefix": "xdc.clock.generated",
		"body": [
			"create_generated_clock -name ${1:clk_div2} \\",
			"    -source [get_pins ${2:u_src_reg/C}] \\",
			"    -divide_by ${3:2} \\",
			"    [get_pins ${4:u_div_reg/Q}]$0"
		],
		"description": "Create generated XDC clock"
	},
	"XDC input delay": {
		"prefix": "xdc.io.input_delay",
		"body": [
			"set_input_delay -clock [get_clocks ${1:sys_clk}] -max ${2:2.0} [get_ports ${3:data_i}]",
			"set_input_delay -clock [get_clocks ${1:sys_clk}] -min ${4:0.5} [get_ports ${3:data_i}]$0"
		],
		"description": "Set external input delay relative to XDC clock"
	},
	"XDC output delay": {
		"prefix": "xdc.io.output_delay",
		"body": [
			"set_output_delay -clock [get_clocks ${1:sys_clk}] -max ${2:1.5} [get_ports ${3:data_o}]",
			"set_output_delay -clock [get_clocks ${1:sys_clk}] -min ${4:0.0} [get_ports ${3:data_o}]$0"
		],
		"description": "Set external output delay relative to XDC clock"
	},
	"XDC package pin": {
		"prefix": "xdc.pin.package",
		"body": "set_property PACKAGE_PIN ${1:AB11} [get_ports ${2:port_name}]$0",
		"description": "Assign package pin"
	},
	"XDC io standard": {
		"prefix": "xdc.io.standard",
		"body": "set_property IOSTANDARD ${1:LVCMOS33} [get_ports ${2:port_name}]$0",
		"description": "Assign IO electrical standard"
	},
	"XDC IO pin config": {
		"prefix": "xdc.io.pin_cfg",
		"body": [
			"set_property PACKAGE_PIN ${1:AB11} [get_ports ${2:port_name}]",
			"set_property IOSTANDARD ${3:LVCMOS33} [get_ports ${2:port_name}]$0"
		],
		"description": "Assign package pin and IO standard together"
	}
}
