{
    "SVA Concurrent Handshake Stable": {
        "prefix": "sva_stable_handshake",
        "body": [
            "// SVA: Payload must be stable when VALID is asserted and READY is low",
            "property p_${1:bus}_stability;",
            "    @(posedge clk) disable iff (!rst_n)",
            "    (${2:valid} && !${3:ready}) |-> \\$stable(${4:data});",
            "endproperty",
            "",
            "assert_${1:bus}_stability: assert property(p_${1:bus}_stability)",
            "    else `uvm_error(\"SVA_VIOLATION\", \"${1:bus} data changed during backpressure stall\");$0"
        ],
        "description": "Checks stability on back-pressured handshakes (AXI-like)"
    },
    "SVA Rose Implication": {
        "prefix": "sva_rose_impl",
        "body": [
            "property p_${1:check_name};",
            "    @(posedge clk) disable iff (!rst_n)",
            "    \\$rose(${2:trigger}) |-> ##${3:1} ${4:consequence};",
            "endproperty",
            "",
            "assert_${1:check_name}: assert property(p_${1:check_name});$0"
        ],
        "description": "Checks that a rising edge immediately implies a sequence"
    },
    "SVA One-Hot Grant": {
        "prefix": "sva_onehot_grant",
        "body": [
            "// SVA: Arbiter grant lines must only have exactly one bit hot",
            "property p_${1:arb}_onehot;",
            "    @(posedge clk) disable iff (!rst_n)",
            "    ${2:req_valid} |-> \\$onehot(${3:grant_bus});",
            "endproperty",
            "",
            "assert_${1:arb}_onehot: assert property (p_${1:arb}_onehot);$0"
        ],
        "description": "Validates Arbiter Grants safely"
    }
}
